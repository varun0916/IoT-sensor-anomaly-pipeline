   "source": [
    "SELECT \n",
    "    s.sensor_identifier,\n",
    "    COUNT(*) as anomaly_count\n",
    "FROM gold.fact_iot_events f\n",
    "JOIN gold.dim_sensor_master s ON f.sensor_sk = s.sensor_sk\n",
    "WHERE ABS(f.z_score) > 1.5  -- Lowered from 3 to see results\n",
    "GROUP BY 1\n",
    "ORDER BY 2 DESC;"
   ]
  }
